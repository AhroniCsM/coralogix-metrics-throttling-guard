# =============================================================================
# Coralogix Metrics Cost-Optimizer — configuration
# =============================================================================
# This is the ONE place you change anything. Every script reads this file, and
# the launchd installer reads a couple of values from it too. You should never
# need to edit the .sh scripts or the .plist files directly.
#
# Each setting below is written as:   NAME="${NAME:-default}"
# That means "use the default shown, unless an environment variable overrides
# it." To change a value, just edit the default (the part after ':-'). E.g. to
# turn blocking on, change   BLOCK_ENABLED="${BLOCK_ENABLED:-false}"
#                     to     BLOCK_ENABLED="${BLOCK_ENABLED:-true}"
#
# IMPORTANT: keep this file (once it has your API key) OUT of version control.
# See .gitignore.
# -----------------------------------------------------------------------------

# =============================================================================
# 1. AUTHENTICATION  (you MUST set CX_API_KEY)
# =============================================================================
# A Coralogix personal or team API key. It needs two things:
#   - read metrics usage:   the "DataAnalytics" permission preset, which grants
#                           METRICS.DATA-ANALYTICS#HIGH:READ
#   - manage blocking rules: permission to Block/Allow metrics
# Create one in the Coralogix UI under: Data Flow > API Keys.
# Paste the key between the quotes, replacing PASTE_YOUR_API_KEY_HERE.
CX_API_KEY="${CX_API_KEY:-PASTE_YOUR_API_KEY_HERE}"

# The exact Authorization header sent to BOTH APIs. Most personal/team keys work
# as "Bearer <key>" (the default below). If the healthcheck fails with an auth
# error (Unauthenticated / code 16), switch to the raw form by changing the
# default to:   Authorization: ${CX_API_KEY}
CX_AUTH_HEADER="${CX_AUTH_HEADER:-Authorization: Bearer ${CX_API_KEY}}"

# =============================================================================
# 2. REGION / ENDPOINT  (you MUST set this to your region)
# =============================================================================
# Both APIs are gRPC/TLS and live on your region's "gRPC Management" host.
# Find it in the Coralogix docs "endpoints" page using the domain selector, or
# match your login region to the table below. Use host:443, no "https://".
#       eu1  -> api.eu1.coralogix.com:443
#       eu2  -> api.eu2.coralogix.com:443
#       us1  -> api.coralogix.us:443
#       us2  -> api.cx498.coralogix.com:443
#       ap1  -> api.app.coralogix.in:443
#       ap2  -> api.coralogixsg.com:443
#       ap3  -> api.ap3.coralogix.com:443
USAGE_ENDPOINT="${USAGE_ENDPOINT:-api.eu1.coralogix.com:443}"

# The blocking-rules (Optimizer) API uses the same regional host by default, so
# you normally don't touch this. ONLY change it if Block/List/Allow fail with
# UNAVAILABLE (14) or NOT_FOUND on the regional host — then try the global
# gateway by setting the default to: ng-api-grpc.app.coralogix.net:443
OPTIMIZER_ENDPOINT="${OPTIMIZER_ENDPOINT:-$USAGE_ENDPOINT}"

# =============================================================================
# 3. WHAT COUNTS AS "OVER BUDGET"
# =============================================================================
# A metric is flagged when its usage for the CURRENT UTC day exceeds this value.
THRESHOLD_UNITS="${THRESHOLD_UNITS:-5}"

# Which usage figure to compare against THRESHOLD_UNITS. One of:
#   unit_usage   -> derived "units" (matches the wording "over N units")  [default]
#   bytes_volume -> raw bytes ingested
#   cardinality  -> active series count
#   sample_count -> number of samples
USAGE_FIELD="${USAGE_FIELD:-unit_usage}"

# Page size when paging metrics from the Usage API. 200 is fine for most.
PAGE_SIZE="${PAGE_SIZE:-200}"

# =============================================================================
# 4. ENFORCEMENT  (controls whether anything is actually blocked)
# =============================================================================
# THE MASTER SWITCH. Default is "false" = DRY-RUN: the detector finds and logs
# over-threshold metrics but blocks NOTHING. Change to "true" only after you've
# reviewed a dry run and confirmed blocking is safe for your dashboards/alerts.
BLOCK_ENABLED="${BLOCK_ENABLED:-false}"

# Safety cap on how many NEW metrics a single detector run may block.
#   0 = unlimited (block everything over threshold — the eventual steady state).
#   1 = block at most one new metric per run; the rest wait for later runs.
# Shipping default is 1, so the very first time you flip BLOCK_ENABLED=true it
# can't blast many metrics at once. Raise it once you trust the behaviour.
MAX_BLOCKS_PER_RUN="${MAX_BLOCKS_PER_RUN:-1}"

# Optional allowlist. If non-empty, ONLY these metric names may ever be blocked,
# regardless of what else is over threshold (comma- or whitespace-separated).
# Perfect for a first live test against one known throwaway metric, e.g.:
#   BLOCK_ALLOWLIST="${BLOCK_ALLOWLIST:-my_test_metric_total}"
# Empty (default) = no allowlist, i.e. any over-threshold metric is eligible
# (subject to MAX_BLOCKS_PER_RUN). NOTE: empty allowlist + BLOCK_ENABLED=true +
# MAX_BLOCKS_PER_RUN=0 means "block everything over threshold" — the most
# aggressive setting; get there gradually.
BLOCK_ALLOWLIST="${BLOCK_ALLOWLIST:-}"

# Max metrics per Block/Allow gRPC call. Requests are chunked at this size and
# partial failures are tolerated. 50 is safe.
CHUNK_SIZE="${CHUNK_SIZE:-50}"

# =============================================================================
# 5. SCHEDULING  (all evaluated in UTC — no local-time/DST math anywhere)
# =============================================================================
# How often the DETECTOR runs, in seconds. The installer writes this into the
# detector launchd plist. 3600 = hourly (recommended). 900 = every 15 min.
# After changing this you must re-run: ./install_launchd.sh install
DETECTOR_INTERVAL_SECONDS="${DETECTOR_INTERVAL_SECONDS:-3600}"

# The UTC hour (0-23) during which the UNBLOCK job does its work. The unblock
# job wakes every hour and exits immediately unless the current UTC hour matches
# this — so the time is set entirely here, in UTC.
#   0 = unblock at 00:00 UTC, right after Coralogix resets daily usage (production).
# Tip: usage resets at 00:00 UTC. In UK summer (BST) that's 01:00 local; in
# winter (GMT) it's 00:00 local. You don't need to care — this is UTC.
UNBLOCK_UTC_HOUR="${UNBLOCK_UTC_HOUR:-0}"

# =============================================================================
# 6. NOTIFICATIONS  (optional, OFF by default)
# =============================================================================
# A shell command run ONLY on meaningful events (never on a quiet tick):
#   * the detector blocked new metrics
#   * a Block or Allow call failed
#   * there were unconfirmed blocks, or metrics deferred by the cap
#   * the unblock job left rules pending after retries
#   * the over-threshold count reached HIGH_WATERMARK
# The JSON summary (with an added "alert" field) is passed on stdin AND as $1.
# A failing command is logged but never aborts a run. Examples:
#   NOTIFY_CMD="${NOTIFY_CMD:-cat >> $DATA_DIR/alerts.txt}"        # append to a file
#   # Slack webhook (Slack needs a top-level "text" field, so wrap it):
#   NOTIFY_CMD='jq -c "{text:(.alert+\"\n\"+tostring)}" | curl -s -XPOST -H "Content-type: application/json" -d @- https://hooks.slack.com/services/XXX/YYY/ZZZ'
# Empty (default) = notifications off.
NOTIFY_CMD="${NOTIFY_CMD:-}"

# Over-threshold count at/above which the detector notifies even if nothing new
# was blocked (e.g. a spike while in dry-run). 0 (default) disables this trigger.
HIGH_WATERMARK="${HIGH_WATERMARK:-0}"

# =============================================================================
# 7. FILE LOCATIONS  (defaults sit next to the scripts; rarely need changing)
# =============================================================================
# Directory for state + logs. Must be writable by whatever runs the schedule.
DATA_DIR="${DATA_DIR:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/data}"

# Shared, date-bucketed record of what THIS automation has blocked (name +
# rule ID per UTC day). The detector adds to today's bucket; only the unblock
# job removes a bucket, and only after it has successfully unblocked it.
STATE_FILE="${STATE_FILE:-$DATA_DIR/state.json}"

# flock target shared by both jobs so they never corrupt state or race.
LOCK_FILE="${LOCK_FILE:-$DATA_DIR/optimizer.lock}"

# Append-only run log (one JSON line per run).
LOG_FILE="${LOG_FILE:-$DATA_DIR/optimizer.log}"

# Latest over-threshold list, overwritten each run (easy to tail / alert on).
OVER_THRESHOLD_FILE="${OVER_THRESHOLD_FILE:-$DATA_DIR/over_threshold_latest.json}"

# How many days of EMPTY (already-unblocked) date buckets to keep for audit.
# Non-empty buckets still owed an unblock are NEVER pruned, regardless of age.
KEEP_DAYS="${KEEP_DAYS:-7}"
